<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cluster_background"
    android:fitsSystemWindows="true"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="20dp">

    <!-- ===== Header bar ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cluster_title"
                android:textColor="@color/cluster_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/cluster_subtitle"
                android:textColor="@color/cluster_text_dim"
                android:textSize="11sp"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <!-- Connection status pill — tap to switch between DEMO and LIVE -->
        <LinearLayout
            android:id="@+id/statusPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_status_pill"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/dot_status" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/status_connecting"
                android:textColor="@color/cluster_text_dim"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Gauges ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Primary: Speedometer -->
        <com.example.obd_telemetry_app.GaugeView
            android:id="@+id/speedGauge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.15"
            android:layout_gravity="center_horizontal" />

        <!-- Secondary: Tachometer -->
        <com.example.obd_telemetry_app.GaugeView
            android:id="@+id/rpmGauge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal" />
    </LinearLayout>

    <!-- ===== Footer status strip ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_limit"
                android:textColor="@color/cluster_text_dim"
                android:textSize="11sp"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/footer_limit_value"
                android:textColor="@color/cluster_text"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="16dp"
            android:background="@color/cluster_divider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_status"
                android:textColor="@color/cluster_text_dim"
                android:textSize="11sp"
                android:letterSpacing="0.12" />

            <TextView
                android:id="@+id/footerStatusValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/footer_status_normal"
                android:textColor="@color/cluster_green"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
